# GJC Platform - Backend Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# MONGODB (Required)
# ===========================================
MONGO_URL=mongodb://localhost:27017
DB_NAME=gjc_platform

# ===========================================
# POSTGRESQL (Required for hybrid architecture)
# ===========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gjc_platform
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password

# ===========================================
# OPENAI API (Required for AI Matching)
# ===========================================
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# ===========================================
# EMERGENT LLM KEY (Optional - for Paula Chat)
# ===========================================
EMERGENT_LLM_KEY=sk-emergent-your-key-here

# ===========================================
# PLATFORM SETTINGS
# ===========================================
PLATFORM_URL=https://gjc.ro
CORS_ORIGINS=*

# ===========================================
# EMAIL (SMTP) Settings
# ===========================================
SMTP_HOST=mail.gjc.ro
SMTP_PORT=465
SMTP_USER=office@gjc.ro
SMTP_PASS=your_smtp_password
ADMIN_EMAIL=office@gjc.ro

# ===========================================
# SECURITY
# ===========================================
PASSWORD_SALT=your_secure_random_salt_here
JWT_SECRET=your_jwt_secret_key_here

# ===========================================
# STORAGE (Emergent Cloud Storage)
# ===========================================
EMERGENT_STORAGE_BUCKET=your_bucket_name
EMERGENT_STORAGE_ACCESS_KEY=your_access_key
EMERGENT_STORAGE_SECRET_KEY=your_secret_key

# ===========================================
# ANTHROPIC (for Document OCR)
# ===========================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
