6:["$","html",null,{"lang":"ro","suppressHydrationWarning":true,"children":["$","body",null,{"className":"__variable_56db2a font-sans antialiased","children":[["$","$La",null,{"locale":"ro","dict":{"metadata":{"title":"Global Jobs Consulting | Recrutare Internațională","description":"Agenție de recrutare internațională specializată în plasarea forței de muncă din Asia și Africa pe piețele europene. Soluții complete de staffing pentru România, Austria și Serbia.","keywords":"recrutare internațională, muncitori asia, muncitori africa, staffing România, agenție recrutare"},"nav":{"home":"Acasă","employers":"Angajatori","candidates":"Candidați","industries":"Industrii","howItWorks":"Cum Funcționează","about":"Despre Noi","blog":"Blog","contact":"Contact","login":"Autentificare","register":"Înregistrare","myAccount":"Contul Meu","dashboard":"Dashboard","logout":"Deconectare","requestWorkers":"Solicită Muncitori"},"hero":{"slide1":{"headline":"Muncitori Internaționali pentru Companii Românești","subheadline":"Soluții legale de recrutare din Asia și Africa","cta":"Solicită Muncitori"},"slide2":{"headline":"Soluții Complete de Staffing","subheadline":"De la selecție la integrare completă","cta":"Află Mai Multe"},"slide3":{"headline":"11+ Parteneri în Asia și Africa","subheadline":"Acces la mii de candidați verificați","cta":"Contactează-ne"}},"stats":{"partners":"Parteneri în Asia & Africa","experience":"Ani de Experiență","markets":"Piețe Europene","candidates":"Candidați Plasați"},"about":{"label":"Despre Noi","title":"Conectăm Talente Globale cu Oportunități Locale","subtitle":"Soluții globale pentru deficit de forță de muncă","text1":"Global Jobs Consulting este o agenție de recrutare cu servicii complete, specializată în plasarea forței de muncă din Asia și Africa pe piețele europene. Cu o rețea de 11 agenții partenere, oferim soluții de staffing complete pentru angajatorii din România, Austria și Serbia.","text2":"Ne ocupăm de întregul proces: de la selecția riguroasă a candidaților, documentația de imigrare (vize și permise de muncă), integrarea în comunitate și monitorizarea pe termen lung.","cta":"Descoperă Serviciile Noastre"},"industries":{"label":"Industrii","title":"Sectoare Acoperite","construction":"Construcții","horeca":"HoReCa","agriculture":"Agricultură","manufacturing":"Producție","logistics":"Logistică"},"contact":{"label":"Contact","title":"Hai să Vorbim","description":"Fie că ești angajator în căutare de personal sau candidat în căutare de oportunități, suntem aici să te ajutăm.","address":"Adresă","phone":"Telefon","email":"Email","schedule":"Program","scheduleValue":"Luni - Vineri: 09:00 - 18:00","form":{"name":"Nume Complet","email":"Email","phone":"Telefon","subject":"Subiect","message":"Mesaj","privacy":"Accept","privacyLink":"Politica de Confidențialitate","send":"Trimite Mesaj","sending":"Se trimite..."}},"footer":{"description":"Agenție de recrutare internațională în România, Austria și Serbia. 11 parteneri în Asia și Africa.","quickLinks":"Link-uri Rapide","industries":"Industrii","contactInfo":"Contact","rights":"Toate drepturile rezervate.","privacy":"Politica de Confidențialitate"},"cta":{"employer":"Sunt Angajator","candidate":"Caut un Job"},"common":{"learnMore":"Află Mai Multe","getStarted":"Începe Acum","submit":"Trimite","cancel":"Anulează","loading":"Se încarcă...","error":"A apărut o eroare","success":"Succes!","required":"Câmp obligatoriu"},"howItWorks":{"title":"Cum Funcționează Procesul GJC","subtitle":"Descoperiți pașii simpli pe care îi parcurgem împreună pentru a asigura cel mai bun rezultat pentru compania sau cariera dumneavoastră.","tabs":{"companies":"Pentru Companii","candidates":"Pentru Candidați","immigration":"Servicii Imigrare"},"steps":{"companies":{"step1":"Înregistrare și verificare CUI","step2":"Postezi cerința de muncitori","step3":"Primești candidați selectați de GJC","step4":"Interviu și selecție finală","step5":"GJC gestionează dosarul IGI","step6":"Muncitorul ajunge la t