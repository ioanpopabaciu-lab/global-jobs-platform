6:["$","html",null,{"lang":"de","suppressHydrationWarning":true,"children":["$","body",null,{"className":"__variable_56db2a font-sans antialiased","children":[["$","$La",null,{"locale":"de","dict":{"metadata":{"title":"Global Jobs Consulting | Internationale Personalvermittlung","description":"Internationale Personalvermittlungsagentur spezialisiert auf die Vermittlung von Arbeitskräften aus Asien und Afrika auf europäische Märkte. Komplettlösungen für Rumänien, Österreich und Serbien.","keywords":"internationale Rekrutierung, asiatische Arbeiter, afrikanische Arbeiter, Personalvermittlung Rumänien, Rekrutierungsagentur"},"nav":{"home":"Startseite","employers":"Arbeitgeber","candidates":"Kandidaten","industries":"Branchen","howItWorks":"So funktioniert's","about":"Über Uns","blog":"Blog","contact":"Kontakt","login":"Anmelden","register":"Registrieren","myAccount":"Mein Konto","dashboard":"Dashboard","logout":"Abmelden","requestWorkers":"Arbeiter Anfordern"},"hero":{"slide1":{"headline":"Internationale Arbeiter für Unternehmen","subheadline":"Legale Rekrutierungslösungen aus Asien und Afrika","cta":"Arbeiter Anfordern"},"slide2":{"headline":"Komplette Personallösungen","subheadline":"Von der Auswahl bis zur vollständigen Integration","cta":"Mehr Erfahren"},"slide3":{"headline":"11+ Partner in Asien und Afrika","subheadline":"Zugang zu Tausenden von verifizierten Kandidaten","cta":"Kontaktieren Sie Uns"}},"stats":{"partners":"Partner in Asien & Afrika","experience":"Jahre Erfahrung","markets":"Europäische Märkte","candidates":"Platzierte Kandidaten"},"about":{"label":"Über Uns","title":"Wir Verbinden Globale Talente mit Lokalen Chancen","subtitle":"Globale Lösungen für den Arbeitskräftemangel","text1":"Global Jobs Consulting ist eine Full-Service-Rekrutierungsagentur, die sich auf die Vermittlung von Arbeitskräften aus Asien und Afrika in europäische Märkte spezialisiert hat. Mit einem Netzwerk von 11 Partneragenturen bieten wir komplette Personallösungen für Arbeitgeber in Rumänien, Österreich und Serbien.","text2":"Wir kümmern uns um den gesamten Prozess: von der sorgfältigen Kandidatenauswahl, der Einwanderungsdokumentation (Visa und Arbeitserlaubnisse), der Gemeinschaftsintegration bis zur langfristigen Überwachung.","cta":"Entdecken Sie Unsere Dienstleistungen"},"industries":{"label":"Branchen","title":"Abgedeckte Sektoren","construction":"Bauwesen","horeca":"Gastgewerbe","agriculture":"Landwirtschaft","manufacturing":"Fertigung","logistics":"Logistik"},"contact":{"label":"Kontakt","title":"Lassen Sie Uns Sprechen","description":"Ob Sie ein Arbeitgeber auf der Suche nach Personal oder ein Kandidat auf der Suche nach Möglichkeiten sind, wir sind hier um zu helfen.","address":"Adresse","phone":"Telefon","email":"E-Mail","schedule":"Öffnungszeiten","scheduleValue":"Montag - Freitag: 09:00 - 18:00","form":{"name":"Vollständiger Name","email":"E-Mail","phone":"Telefon","subject":"Betreff","message":"Nachricht","privacy":"Ich akzeptiere die","privacyLink":"Datenschutzrichtlinie","send":"Nachricht Senden","sending":"Wird gesendet..."}},"footer":{"description":"Internationale Rekrutierungsagentur in Rumänien, Österreich und Serbien. 11 Partner in Asien und Afrika.","quickLinks":"Schnelllinks","industries":"Branchen","contactInfo":"Kontakt","rights":"Alle Rechte vorbehalten.","privacy":"Datenschutzrichtlinie"},"cta":{"employer":"Ich bin Arbeitgeber","candidate":"Ich Suche Arbeit"},"common":{"learnMore":"Mehr Erfahren","getStarted":"Jetzt Starten","submit":"Absenden","cancel":"Abbrechen","loading":"Wird geladen...","error":"Ein Fehler ist aufgetreten","success":"Erfolg!","required":"Pflichtfeld"},"howItWorks":{"title":"How the GJC Process Works","subtitle":"Discover the simple steps we take together to ensure the best outcome for your company or career.","tabs":{"companies":"For Companies","candidates":"For Candidates","immigration":"Immigration Services"},"steps":{"companies":{"step1":"Registration and VAT Check","step2":"Post worker requirements","step3":"Receive GJC-selected candidates","step4":"Interview and final selection","step5":"GJC handles the IGI file","step6":"The worker arrives to you ✅"},"candidates":{"step1":"Registration and profile completion","step2":"Upload documents (passport, diplomas)","step3":"Matching with suitable jobs","step4":"Interview with the employer","step5":"GJC handles the visa and permit","step6":"You leave for your new job ✅"},"immigration":{"step1":"Free consultation with GJC","step2":"File evaluation and eligibility","step3":"Preparation of required documents","step4":"Filing with local authorities","step5":"Tracking and GJC representation","step6":"You get the requested document ✅"}}},"requestWorkers":{"title":"Request International Workers","subtitle":"Fill out the form and we will contact you in 24 hours","section1":{"title":"Company Details & Contact","companyName":"Company Name *","companyNamePlaceholder":"e.g. GJC SRL","cui":"Company VAT Number (CUI) *","cuiPlaceholder":"e.g. RO12345678","verify":"Verify","verifySuccess":"✅ Company validated according to ANAF.","verifyError":"❌ Verification error.","contactPerson":"Contact Person *","contactPersonPlaceholder":"Full Name","phone":"Phone *","phonePlaceholder":"+40 700 000 000","email":"Email *","emailPlaceholder":"office@company.com"},"section2":{"title":"Job Information","jobTitle":"Desired Position *","jobTitlePlaceholder":"e.g. Mason, Welder, Chef...","workersNeeded":"Number of Workers Needed *","workersNeededPlaceholder":"e.g. 5","preferredCountry":"Preferred Candidate Country","countries":{"any":"Any Country","asia":"Asia","africa":"Africa","nepal":"Nepal","india":"India","pakistan":"Pakistan","bangladesh":"Bangladesh","others":"Others"},"workSchedule":"Work Schedule","schedules":{"fullTime":"Full-time","partTime":"Part-time","shifts":"Shifts","night":"Night"},"salary":"Offered Salary (RON/month net) - optional but recommended","salaryPlaceholder":"e.g. 3500 RON"},"section3":{"title":"Special Condi