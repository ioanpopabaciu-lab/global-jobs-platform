6:["$","html",null,{"lang":"bn","suppressHydrationWarning":true,"children":["$","body",null,{"className":"__variable_56db2a font-sans antialiased","children":[["$","$La",null,{"locale":"bn","dict":{"metadata":{"title":"Global Jobs Consulting | আন্তর্জাতিক নিয়োগ","description":"এশিয়া এবং আফ্রিকা থেকে ইউরোপীয় বাজারে কর্মশক্তি নিয়োগে বিশেষায়িত আন্তর্জাতিক নিয়োগ সংস্থা। রোমানিয়া, অস্ট্রিয়া এবং সার্বিয়ার জন্য সম্পূর্ণ স্টাফিং সমাধান।","keywords":"আন্তর্জাতিক নিয়োগ, এশীয় কর্মী, আফ্রিকান কর্মী, রোমানিয়া স্টাফিং, নিয়োগ সংস্থা"},"nav":{"home":"হোম","employers":"নিয়োগকর্তা","candidates":"প্রার্থী","industries":"শিল্প","howItWorks":"কিভাবে কাজ করে","about":"আমাদের সম্পর্কে","blog":"ব্লগ","contact":"যোগাযোগ","login":"লগইন","register":"রেজিস্টার","myAccount":"আমার অ্যাকাউন্ট","dashboard":"ড্যাশবোর্ড","logout":"লগআউট","requestWorkers":"কর্মী অনুরোধ"},"hero":{"slide1":{"headline":"কোম্পানিগুলির জন্য আন্তর্জাতিক কর্মী","subheadline":"এশিয়া এবং আফ্রিকা থেকে আইনি নিয়োগ সমাধান","cta":"কর্মী অনুরোধ করুন"},"slide2":{"headline":"সম্পূর্ণ স্টাফিং সমাধান","subheadline":"নির্বাচন থেকে সম্পূর্ণ একীভূতকরণ পর্যন্ত","cta":"আরও জানুন"},"slide3":{"headline":"এশিয়া ও আফ্রিকায় ১১+ অংশীদার","subheadline":"হাজার হাজার যাচাইকৃত প্রার্থীদের অ্যাক্সেস","cta":"যোগাযোগ করুন"}},"stats":{"partners":"এশিয়া ও আফ্রিকায় অংশীদার","experience":"বছরের অভিজ্ঞতা","markets":"ইউরোপীয় বাজার","candidates":"নিয়োগপ্রাপ্ত প্রার্থী"},"about":{"label":"আমাদের সম্পর্কে","title":"গ্লোবাল ট্যালেন্টকে স্থানীয় সুযোগের সাথে সংযুক্ত করা","subtitle":"কর্মশক্তির ঘাটতির জন্য গ্লোবাল সমাধান","text1":"Global Jobs Consulting হল একটি সম্পূর্ণ-সেবা নিয়োগ সংস্থা যা এশিয়া এবং আফ্রিকা থেকে ইউরোপীয় বাজারে কর্মশক্তি নিয়োগে বিশেষায়িত। ১১টি অংশীদার সংস্থার নেটওয়ার্ক সহ, আমরা রোমানিয়া, অস্ট্রিয়া এবং সার্বিয়ার নিয়োগকর্তাদের জন্য সম্পূর্ণ স্টাফিং সমাধান অফার করি।","text2":"আমরা সম্পূর্ণ প্রক্রিয়া পরিচালনা করি: কঠোর প্রার্থী নির্বাচন থেকে, অভিবাসন ডকুমেন্টেশন (ভিসা এবং কাজের অনুমতি), সম্প্রদায় একীভূতকরণ এবং দীর্ঘমেয