7:["$","html",null,{"lang":"bn","suppressHydrationWarning":true,"children":["$","body",null,{"className":"__variable_56db2a font-sans antialiased","children":[["$","$Lb",null,{"locale":"bn","dict":{"metadata":{"title":"Global Jobs Consulting | আন্তর্জাতিক নিয়োগ","description":"এশিয়া এবং আফ্রিকা থেকে ইউরোপীয় বাজারে কর্মশক্তি নিয়োগে বিশেষায়িত আন্তর্জাতিক নিয়োগ সংস্থা। রোমানিয়া, অস্ট্রিয়া এবং সার্বিয়ার জন্য সম্পূর্ণ স্টাফিং সমাধান।","keywords":"আন্তর্জাতিক নিয়োগ, এশীয় কর্মী, আফ্রিকান কর্মী, রোমানিয়া স্টাফিং, নিয়োগ সংস্থা"},"nav":{"home":"হোম","employers":"নিয়োগকর্তা","candidates":"প্রার্থী","industries":"শিল্প","howItWorks":"কিভাবে কাজ করে","about":"আমাদের সম্পর্কে","blog":"ব্লগ","contact":"যোগাযোগ","login":"লগইন","register":"রেজিস্টার","myAccount":"আমার অ্যাকাউন্ট","dashboard":"ড্যাশবোর্ড","logout":"লগআউট","requestWorkers":"কর্মী অনুরোধ"},"hero":{"slide1":{"headline":"কোম্পানিগুলির জন্য আন্তর্জাতিক কর্মী","subheadline":"এশিয়া এবং আফ্রিকা থেকে আইনি নিয়োগ সমাধান","cta":"কর্মী অনুরোধ করুন"},"slide2":{"headline":"সম্পূর্ণ স্টাফিং সমাধান","subheadline":"নির্বাচন থেকে সম্পূর্ণ একীভূতকরণ পর্যন্ত","cta":"আরও জানুন"},"slide3":{"headline":"এশিয়া ও আফ্রিকায় ১১+ অংশীদার","subheadline":"হাজার হাজার যাচাইকৃত প্রার্থীদের অ্যাক্সেস","cta":"যোগাযোগ করুন"}},"stats":{"partners":"এশিয়া ও আফ্রিকায় অংশীদার","experience":"বছরের অভিজ্ঞতা","markets":"ইউরোপীয় বাজার","candidates":"নিয়োগপ্রাপ্ত প্রার্থী"},"about":{"label":"আমাদের সম্পর্কে","title":"গ্লোবাল ট্যালেন্টকে স্থানীয় সুযোগের সাথে সংযুক্ত করা","subtitle":"কর্মশক্তির ঘাটতির জন্য গ্লোবাল সমাধান","text1":"Global Jobs Consulting হল একটি সম্পূর্ণ-সেবা নিয়োগ সংস্থা যা এশিয়া এবং আফ্রিকা থেকে ইউরোপীয় বাজারে কর্মশক্তি নিয়োগে বিশেষায়িত। ১১টি অংশীদার সংস্থার নেটওয়ার্ক সহ, আমরা রোমানিয়া, অস্ট্রিয়া এবং সার্বিয়ার নিয়োগকর্তাদের জন্য সম্পূর্ণ স্টাফিং সমাধান অফার করি।","text2":"আমরা সম্পূর্ণ প্রক্রিয়া পরিচালনা করি: কঠোর প্রার্থী নির্বাচন থেকে, অভিবাসন ডকুমেন্টেশন (ভিসা এবং কাজের অনুমতি), সম্প্রদায় একীভূতকরণ এবং দীর্ঘমেয়াদী পর্যবেক্ষণ।","cta":"আমাদের সেবা আবিষ্কার করুন"},"industries":{"label":"শিল্প","title":"কভার করা সেক্টরগুলি","construction":"নির্মাণ","horeca":"হোটেল ও রেস্তোরাঁ","agriculture":"কৃষি","manufacturing":"উৎপাদন","logistics":"পরিবহন"},"contact":{"label":"যোগাযোগ","title":"আসুন কথা বলি","description":"আপনি কর্মী খুঁজছেন এমন নিয়োগকর্তা হন বা সুযোগ খুঁজছেন এমন প্রার্থী, আমরা সাহায্য করতে এখানে আছি।","address":"ঠিকানা","phone":"ফোন","email":"ইমেইল","schedule":"সময়সূচী","scheduleValue":"সোমবার - শুক্রবার: ০৯:০০ - ১৮:০০","form":{"name":"পুরো নাম","email":"ইমেইল","phone":"ফোন","subject":"বিষয়","message":"বার্তা","privacy":"আমি স্বীকার করি","privacyLink":"গোপনীয়তা নীতি","send":"বার্তা পাঠান","sending":"পাঠানো হচ্ছে..."}},"footer":{"description":"রোমানিয়া, অস্ট্রিয়া এবং সার্বিয়ায় আন্তর্জাতিক নিয়োগ সংস্থা। এশিয়া ও আফ্রিকায় ১১ অংশীদার।","quickLinks":"দ্রুত লিঙ্ক","industries":"শিল্প","contactInfo":"যোগাযোগ","rights":"সর্বস্বত্ব সংরক্ষিত।","privacy":"গোপনীয়তা নীতি"},"cta":{"employer":"আমি একজন নিয়োগকর্তা","candidate":"আমি চাকরি খুঁজছি"},"common":{"learnMore":"আরও জানুন","getStarted":"এখনই শুরু করুন","submit":"জমা দিন","cancel":"বাতিল","loading":"লোড হচ্ছে...","error":"একটি ত্রুটি ঘটেছে","success":"সাফল্য!","required":"প্রয়োজনীয় ক্ষেত্র"},"howItWorks":{"title":"How the GJC Process Works","subtitle":"Discover the simple steps we take together to ensure the best outcome for your company or career.","tabs":{"companies":"For Companies","candidates":"For Candidates","immigration":"Immigration Services"},"steps":{"companies":{"step1":"Registration and VAT Check","step2":"Post worker requirements","step3":"Receive GJC-selected candidates","step4":"Interview and final selection","step5":"GJC handles the IGI file","step6":"The worker arrives to you ✅"},"candidates":{"step1":"Registration and profile completion","step2":"Upload documents (passport, diplomas)","step3":"Matching with suitable jobs","step4":"Interview with the employer","step5":"GJC handles the visa and permit