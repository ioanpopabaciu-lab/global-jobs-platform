6:["$","html",null,{"lang":"ne","suppressHydrationWarning":true,"children":["$","body",null,{"className":"__variable_56db2a font-sans antialiased","children":[["$","$La",null,{"locale":"ne","dict":{"metadata":{"title":"Global Jobs Consulting | अन्तर्राष्ट्रिय भर्ती","description":"एशिया र अफ्रिकाबाट युरोपेली बजारमा कामदार राख्न विशेषज्ञ अन्तर्राष्ट्रिय भर्ती एजेन्सी। रोमानिया, अष्ट्रिया र सर्बियाको लागि पूर्ण स्टाफिङ समाधानहरू।","keywords":"अन्तर्राष्ट्रिय भर्ती, एशियाली कामदारहरू, अफ्रिकी कामदारहरू, रोमानिया स्टाफिङ, भर्ती एजेन्सी"},"nav":{"home":"गृहपृष्ठ","employers":"रोजगारदाता","candidates":"उम्मेदवार","industries":"उद्योग","howItWorks":"कसरी काम गर्छ","about":"हाम्रो बारेमा","blog":"ब्लग","contact":"सम्पर्क","login":"लग इन","register":"दर्ता गर्नुहोस्","myAccount":"मेरो खाता","dashboard":"ड्यासबोर्ड","logout":"लग आउट","requestWorkers":"कामदार अनुरोध"},"hero":{"slide1":{"headline":"कम्पनीहरूका लागि अन्तर्राष्ट्रिय कामदारहरू","subheadline":"एशिया र अफ्रिकाबाट कानूनी भर्ती समाधानहरू","cta":"कामदार अनुरोध गर्नुहोस्"},"slide2":{"headline":"पूर्ण स्टाफिङ समाधानहरू","subheadline":"छनोटदेखि पूर्ण एकीकरणसम्म","cta":"थप जान्नुहोस्"},"slide3":{"headline":"एशिया र अफ्रिकामा ११+ साझेदारहरू","subheadline":"हजारौं प्रमाणित उम्मेदवारहरूमा पहुँच","cta":"सम्पर्क गर्नुहोस्"}},"stats":{"partners":"एशिया र अफ्रिकामा साझेदारहरू","experience":"वर्षको अनुभव","markets":"युरोपेली बजारहरू","candidates":"राखिएका उम्मेदवारहरू"},"about":{"label":"हाम्रो बारेमा","title":"विश्वव्यापी प्रतिभालाई स्थानीय अवसरसँग जोड्दै","subtitle":"श्रमिक अभावको लागि विश्वव्यापी समाधानहरू","text1":"Global Jobs Consulting एक पूर्ण-सेवा भर्ती एजेन्सी हो जुन एशिया र अफ्रिकाबाट युरोपेली बजारमा कामदार राख्नमा विशेषज्ञ छ। ११ साझेदार एजेन्सीहरूको नेटवर्कको साथ, हामी रोमानिया, अष्ट्रिया र सर्बियाका रोजगारदाताहरूलाई पूर्ण स्टाफिङ समाधानहरू प्रदान गर्छौं।","text2":"हामी सम्पूर्ण प्रक्रिया ह्यान्डल गर्छौं: कडा उम्मेदवार छनोटदेखि, आप्रवासन कागजात (भिसा र कार्य अनुमति), समुदाय एकीकरण र दीर्घकालीन अनुगमनसम्म।","cta":"हाम्रा