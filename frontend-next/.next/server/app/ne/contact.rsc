6:["$","html",null,{"lang":"ne","suppressHydrationWarning":true,"children":["$","body",null,{"className":"__variable_56db2a font-sans antialiased","children":[["$","$La",null,{"locale":"ne","dict":{"metadata":{"title":"Global Jobs Consulting | अन्तर्राष्ट्रिय भर्ती","description":"एशिया र अफ्रिकाबाट युरोपेली बजारमा कामदार राख्न विशेषज्ञ अन्तर्राष्ट्रिय भर्ती एजेन्सी। रोमानिया, अष्ट्रिया र सर्बियाको लागि पूर्ण स्टाफिङ समाधानहरू।","keywords":"अन्तर्राष्ट्रिय भर्ती, एशियाली कामदारहरू, अफ्रिकी कामदारहरू, रोमानिया स्टाफिङ, भर्ती एजेन्सी"},"nav":{"home":"गृहपृष्ठ","employers":"रोजगारदाता","candidates":"उम्मेदवार","industries":"उद्योग","howItWorks":"कसरी काम गर्छ","about":"हाम्रो बारेमा","blog":"ब्लग","contact":"सम्पर्क","login":"लग इन","register":"दर्ता गर्नुहोस्","myAccount":"मेरो खाता","dashboard":"ड्यासबोर्ड","logout":"लग आउट","requestWorkers":"कामदार अनुरोध"},"hero":{"slide1":{"headline":"कम्पनीहरूका लागि अन्तर्राष्ट्रिय कामदारहरू","subheadline":"एशिया र अफ्रिकाबाट कानूनी भर्ती समाधानहरू","cta":"कामदार अनुरोध गर्नुहोस्"},"slide2":{"headline":"पूर्ण स्टाफिङ समाधानहरू","subheadline":"छनोटदेखि पूर्ण एकीकरणसम्म","cta":"थप जान्नुहोस्"},"slide3":{"headline":"एशिया र अफ्रिकामा ११+ साझेदारहरू","subheadline":"हजारौं प्रमाणित उम्मेदवारहरूमा पहुँच","cta":"सम्पर्क गर्नुहोस्"}},"stats":{"partners":"एशिया र अफ्रिकामा साझेदारहरू","experience":"वर्षको अनुभव","markets":"युरोपेली बजारहरू","candidates":"राखिएका उम्मेदवारहरू"},"about":{"label":"हाम्रो बारेमा","title":"विश्वव्यापी प्रतिभालाई स्थानीय अवसरसँग जोड्दै","subtitle":"श्रमिक अभावको लागि विश्वव्यापी समाधानहरू","text1":"Global Jobs Consulting एक पूर्ण-सेवा भर्ती एजेन्सी हो जुन एशिया र अफ्रिकाबाट युरोपेली बजारमा कामदार राख्नमा विशेषज्ञ छ। ११ साझेदार एजेन्सीहरूको नेटवर्कको साथ, हामी रोमानिया, अष्ट्रिया र सर्बियाका रोजगारदाताहरूलाई पूर्ण स्टाफिङ समाधानहरू प्रदान गर्छौं।","text2":"हामी सम्पूर्ण प्रक्रिया ह्यान्डल गर्छौं: कडा उम्मेदवार छनोटदेखि, आप्रवासन कागजात (भिसा र कार्य अनुमति), समुदाय एकीकरण र दीर्घकालीन अनुगमनसम्म।","cta":"हाम्रा सेवाहरू पत्ता लगाउनुहोस्"},"industries":{"label":"उद्योग","title":"कभर गरिएका क्षेत्रहरू","construction":"निर्माण","horeca":"होटल र रेस्टुरेन्ट","agriculture":"कृषि","manufacturing":"उत्पादन","logistics":"ढुवानी"},"contact":{"label":"सम्पर्क","title":"कुरा गरौं","description":"तपाईं कर्मचारी खोज्ने रोजगारदाता होस् वा अवसर खोज्ने उम्मेदवार, हामी मद्दत गर्न यहाँ छौं।","address":"ठेगाना","phone":"फोन","email":"इमेल","schedule":"समय तालिका","scheduleValue":"सोमबार - शुक्रबार: ०९:०० - १८:००","form":{"name":"पूरा नाम","email":"इमेल","phone":"फोन","subject":"विषय","message":"सन्देश","privacy":"म स्वीकार गर्छु","privacyLink":"गोपनीयता नीति","send":"सन्देश पठाउनुहोस्","sending":"पठाउँदै..."}},"footer":{"description":"रोमानिया, अष्ट्रिया र सर्बियामा अन्तर्राष्ट्रिय भर्ती एजेन्सी। एशिया र अफ्रिकामा ११ साझेदारहरू।","quickLinks":"छिटो लिंकहरू","industries":"उद्योग","contactInfo":"सम्पर्क","rights":"सबै अधिकार सुरक्षित।","privacy":"गोपनीयता नीति"},"cta":{"employer":"म रोजगारदाता हुँ","candidate":"म काम खोज्दै छु"},"common":{"learnMore":"थप जान्नुहोस्","getStarted":"अहिले सुरु गर्नुहोस्","submit":"पेश गर्नुहोस्","cancel":"रद्द गर्नुहोस्","loading":"लोड हुँदैछ...","error":"त्रुटि भयो","success":"सफलता!","required":"आवश्यक क्षेत्र"}}}],["$","main",null,{"className":"min-h-screen pt-[120px]","children":["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","$4","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]}],["$","footer",null,{"className":"bg-navy-900 text-white","data-testid":"footer","children":[["$","div",null,{"className":"container mx-auto px-4 py-12","children":["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8","children":[["$","div",null,{"children":[["$","$L8",null,{"src":"/images/optimized/logo_white_v2.webp","alt":"Global Jobs Consult