6:["$","html",null,{"lang":"hi","suppressHydrationWarning":true,"children":["$","body",null,{"className":"__variable_56db2a font-sans antialiased","children":[["$","$La",null,{"locale":"hi","dict":{"metadata":{"title":"Global Jobs Consulting | अंतर्राष्ट्रीय भर्ती","description":"एशिया और अफ्रीका से यूरोपीय बाजारों में कार्यबल रखने में विशेषज्ञ अंतर्राष्ट्रीय भर्ती एजेंसी। रोमानिया, ऑस्ट्रिया और सर्बिया के लिए पूर्ण स्टाफिंग समाधान।","keywords":"अंतर्राष्ट्रीय भर्ती, एशियाई कामगार, अफ्रीकी कामगार, रोमानिया स्टाफिंग, भर्ती एजेंसी"},"nav":{"home":"होम","employers":"नियोक्ता","candidates":"उम्मीदवार","industries":"उद्योग","howItWorks":"यह कैसे काम करता है","about":"हमारे बारे में","blog":"ब्लॉग","contact":"संपर्क","login":"लॉगिन","register":"रजिस्टर","myAccount":"मेरा खाता","dashboard":"डैशबोर्ड","logout":"लॉगआउट","requestWorkers":"कर्मचारी अनुरोध"},"hero":{"slide1":{"headline":"कंपनियों के लिए अंतर्राष्ट्रीय कर्मचारी","subheadline":"एशिया और अफ्रीका से कानूनी भर्ती समाधान","cta":"कर्मचारी अनुरोध करें"},"slide2":{"headline":"पूर्ण स्टाफिंग समाधान","subheadline":"चयन से पूर्ण एकीकरण तक","cta":"अधिक जानें"},"slide3":{"headline":"एशिया और अफ्रीका में 11+ भागीदार","subheadline":"हजारों सत्यापित उम्मीदवारों तक पहुंच","cta":"संपर्क करें"}},"stats":{"partners":"एशिया और अफ्रीका में भागीदार","experience":"वर्षों का अनुभव","markets":"यूरोपीय बाजार","candidates":"नियुक्त उम्मीदवार"},"about":{"label":"हमारे बारे में","title":"वैश्विक प्रतिभा को स्थानीय अवसरों से जोड़ना","subtitle":"कार्यबल की कमी के लिए वैश्विक समाधान","text1":"Global Jobs Consulting एक पूर्ण-सेवा भर्ती एजेंसी है जो एशिया और अफ्रीका से यूरोपीय बाजारों में कार्यबल रखने में विशेषज्ञ है। 11 भागीदार एजेंसियों के नेटवर्क के साथ, हम रोमानिया, ऑस्ट्रिया और सर्बिया में नियोक्ताओं के लिए पूर्ण स्टाफिंग समाधान प्रदान करते हैं।","text2":"हम पूरी प्रक्रिया संभालते हैं: कठोर उम्मीदवार चयन से, आप्रवासन दस्तावेज (वीजा और कार्य परमिट), समुदाय एकीकरण और दीर्घकालिक निगरानी तक।","cta":"हमारी सेवाएं खोजें"},"industries":{"label":"उद्योग","title":"कवर किए गए क्षेत्र","construction":"निर्माण","horeca":"होटल और रेस्टोरेंट","agriculture":"कृषि","manufacturing":"विनिर्माण","logistics":"परिवहन"},"contact":{"label":"संपर्क","title":"बात करते हैं","description":"चाहे आप स्टाफ की तलाश में नियोक्ता हों या अवसर की तलाश में उम्मीदवार, हम मदद के लिए यहां हैं।","address":"पता","phone":"फोन","email":"ईमेल","schedule":"समय","scheduleValue":"सोमवार - शुक्रवार: 09:00 - 18:00","form":{"name":"पूरा नाम","email":"ईमेल","phone":"फोन","subject":"विषय","message":"संदेश","privacy":"मैं स्वीकार करता हूं","privacyLink":"गोपनीयता नीति","send":"संदेश भेजें","sending":"भेजा जा रहा है..."}},"footer":{"description":"रोमानिया, ऑस्ट्रिया और सर्बिया में अंतर्राष्ट्रीय भर्ती एजेंसी। एशिया और अफ्रीका में 11 भागीदार।","quickLinks":"त्वरित लिंक","industries":"उद्योग","contactInfo":"संपर्क","rights":"सर्वाधिकार सुरक्षित।","privacy":"गोपनीयता नीति"},"cta":{"employer":"मैं एक नियोक्ता हूं","candidate":"मैं नौकरी ढूंढ रहा हूं"},"common":{"learnMore":"अधिक जानें","getStarted":"अभी शुरू करें","submit":"जमा करें","cancel":"रद्द करें","loading":"लोड हो रहा है...","error":"एक त्रुटि हुई","success":"सफलता!","required":"आवश्यक फ़ील्ड"}}}],["$","main",null,{"className":"min-h-screen pt-[120px]","children":["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","$4","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]}],["$","footer",null,{"className":"bg-navy-900 text-white","data-testid":"footer","children":[["$","div",null,{"className":"container mx-auto px-4 py-12","children":["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8","children":[["$","div",null,{"children":[["$","$L8",null,{"src":"https://customer-assets.emergentagent.com/job_8604c03f-19f0-4831-97c4-2be3c85c8b29/artifacts/8oq3cjun_GJC%20alb%20transpare