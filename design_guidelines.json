  "layout_strategies": {
    "hero_section": {
      "type": "Full-screen Slider",
      "instructions": "Use a full-screen carousel with a dark overlay (bg-black/40) to ensure text readability. The text should be bold, uppercase, and centered or left-aligned with a strong 'Apply Now' CTA. Use the 'Barlow Condensed' font for the main headline."
    },
    "services_grid": {
      "type": "Bento Grid (Mode A)",
      "instructions": "Do not use equal squares. Use a mix of col-span-1, col-span-2, and row-span-2 to create visual interest. Each service card should have a subtle hover effect (lift + shadow)."
    },
    "forms": {
      "type": "Multi-step Wizard",
      "instructions": "Break down the Employer and Candidate forms into steps (e.g., Personal Info -> Experience -> Uploads). Use Shadcn 'Form' components. Ensure the 'Upload CV' area is prominent."
    },
    "navigation": {
      "type": "Sticky Glassmorphism",
      "instructions": "The navbar should be sticky at the top with a backdrop-blur-md and a semi-transparent white background (bg-white/90). Use the Navy Blue logo."
    }
  },
  "component_rules": {
    "buttons": "Use sharp or slightly rounded corners (rounded-sm). Primary buttons should be Navy Blue (#003366) with White text. Secondary buttons should be Outline or Ghost.",
    "cards": "Clean white cards with a subtle border (border-gray-200) and a soft shadow. No heavy drop shadows.",
    "inputs": "Standard Shadcn inputs with a focus ring of the primary color."
  },
  "universal_guidelines": [
    "Do not use gradients for the main background; keep it clean white or very light grey (#F9FAFB).",
    "Ensure high contrast for all text. Navy Blue on White is excellent.",
    "Use 'Barlow Condensed' for all headings to give that 'Industrial/Corporate' feel.",
    "Add 'data-testid' to all interactive elements.",
    "Mobile responsiveness is critical; ensure the hero slider works well on touch devices."
  ]
